{
  "project": "sidex",
  "version": "0.1.0",
  "description": "Tauri port of VSCode",
  "source_reference": "microsoft/vscode (MIT License)",
  "target_platform": "tauri-v2",
  "methodology": "clean-room architectural replication",
  "layers": {
    "base": {
      "description": "Foundation utilities",
      "sublayers": {
        "common": { "strategy": "reuse", "status": "done" },
        "browser": { "strategy": "reuse", "status": "done" },
        "worker": { "strategy": "reuse", "status": "done" },
        "node": { "strategy": "rewrite-rust", "status": "done" },
        "parts/ipc": { "strategy": "rewrite-tauri", "status": "done" },
        "parts/storage": { "strategy": "rewrite-rust", "status": "done" }
      }
    },
    "platform": {
      "description": "Platform services via dependency injection",
      "service_count": 93,
      "strategy": "mixed-reuse-rewrite",
      "status": "partial"
    },
    "editor": {
      "description": "Monaco text editor core",
      "sublayers": {
        "common": { "strategy": "reuse", "status": "done" },
        "browser": { "strategy": "reuse", "status": "done" },
        "contrib": { "strategy": "reuse", "status": "done", "contribution_count": 57 },
        "standalone": { "strategy": "removed", "status": "deleted" }
      }
    },
    "workbench": {
      "description": "IDE shell — features, services, visual Parts",
      "sublayers": {
        "browser": { "strategy": "reuse-with-mods", "status": "done" },
        "common": { "strategy": "reuse", "status": "done" },
        "contrib": { "strategy": "incremental-port", "status": "partial", "feature_count": 92 },
        "services": { "strategy": "incremental-port", "status": "partial", "service_count": 90 },
        "api": { "strategy": "port", "status": "in-progress" }
      }
    },
    "code": {
      "description": "Application entry point",
      "sublayers": {
        "electron-main": { "strategy": "rewrite-rust", "status": "done" },
        "electron-browser": { "strategy": "rewrite-tauri", "status": "done" }
      }
    }
  },
  "rust_backend": {
    "commands": [
      "fs::read_file", "fs::write_file", "fs::read_dir", "fs::stat", "fs::mkdir",
      "fs::remove", "fs::rename", "fs::exists",
      "terminal::spawn", "terminal::write", "terminal::resize", "terminal::kill",
      "search::search_files", "search::search_text",
      "window::create_window", "window::close_window", "window::set_window_title",
      "os::get_os_info", "os::get_env", "os::get_shell",
      "storage::get", "storage::set", "storage::delete",
      "git::status", "git::diff", "git::log"
    ],
    "native_replacements": {
      "node-pty": "portable-pty",
      "@parcel/watcher": "notify",
      "@vscode/sqlite3": "rusqlite",
      "@vscode/spdlog": "tracing"
    }
  }
}
